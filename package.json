{
  "name": "autovideopipelinegeneration",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,yellow \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "vite --host 127.0.0.1",
    "dev:server": "bun --watch server/main.ts",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json",
    "preview": "vite preview --host 127.0.0.1",
    "test": "npm run test:contracts && npm run test:server && npm run test:ui && npm run test:providers && npm run test:edit",
    "test:contracts": "vitest run shared",
    "test:server": "bun test server --timeout 30000",
    "test:ui": "vitest run src",
    "test:providers": "bun test server/providers --timeout 30000",
    "test:edit": "bun test server/media --timeout 30000",
    "test:media": "bun scripts/verify-media.ts",
    "test:e2e": "playwright test",
    "preflight": "bun scripts/preflight.ts",
    "demo:real": "bun scripts/demo-real.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "ajv": "^8.20.0",
    "gsap": "^3.15.0",
    "hono": "^4.12.28",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "hyperframes": "^0.7.46",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.10"
  }
}
